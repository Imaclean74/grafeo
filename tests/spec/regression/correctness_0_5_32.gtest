# Regression tests for 0.5.32 correctness fixes
#
# Covers GROUP BY on list-valued keys (labels), GROUP BY on date properties,
# ORDER BY with complex expressions (no synthetic column leak), and SPARQL
# ORDER BY with function expressions.

meta:
  language: gql
  model: lpg
  section: regression
  title: "0.5.32 correctness fixes"
  dataset: empty

tests:

  # ---------------------------------------------------------------------------
  # GROUP BY labels(n): multi-label nodes must produce distinct groups
  # Regression for push-based aggregator hash collisions (bug 20) and
  # pull-based GroupKeyPart catch-all (bug 24).
  # ---------------------------------------------------------------------------

  - name: group_by_labels_multi_label
    setup:
      - "INSERT (:Person {name: 'Alix'})"
      - "INSERT (:Person:Employee {name: 'Gus'})"
      - "INSERT (:Person:Employee {name: 'Jules'})"
      - "INSERT (:Company {name: 'GrafeoDB'})"
    query: |
      MATCH (n) RETURN labels(n) AS lbl, count(*) AS cnt
      ORDER BY cnt DESC
    expect:
      count: 3

  - name: group_by_labels_single_label
    setup:
      - "INSERT (:Person {name: 'Alix'})"
      - "INSERT (:Person {name: 'Gus'})"
      - "INSERT (:Company {name: 'GrafeoDB'})"
    query: |
      MATCH (n) RETURN labels(n) AS lbl, count(*) AS cnt
      ORDER BY cnt DESC
    expect:
      ordered: true
      rows:
        - [["Person"], 2]
        - [["Company"], 1]

  # ---------------------------------------------------------------------------
  # GROUP BY on date-valued property
  # ---------------------------------------------------------------------------

  - name: group_by_date_property
    setup:
      - "INSERT (:Event {name: 'A', day: date('2024-06-15')})"
      - "INSERT (:Event {name: 'B', day: date('2024-06-15')})"
      - "INSERT (:Event {name: 'C', day: date('2024-12-25')})"
    query: |
      MATCH (e:Event) RETURN e.day AS day, count(*) AS cnt
      ORDER BY cnt DESC
    expect:
      count: 2

  # ---------------------------------------------------------------------------
  # ORDER BY with complex expressions: no synthetic column leak (bug 23)
  # ---------------------------------------------------------------------------

  - name: order_by_labels_no_extra_columns
    # Result columns must contain only what RETURN specifies, no __expr_*
    setup:
      - "INSERT (:Person {name: 'Gus'})"
      - "INSERT (:Person {name: 'Alix'})"
    query: MATCH (n:Person) RETURN n.name ORDER BY labels(n)[0]
    expect:
      columns: ["n.name"]
      count: 2

  - name: order_by_arithmetic_no_extra_columns
    setup:
      - "INSERT (:Person {name: 'Alix', age: 30})"
      - "INSERT (:Person {name: 'Gus', age: 25})"
    query: MATCH (n:Person) RETURN n.name, n.age ORDER BY n.age + 1
    expect:
      columns: ["n.name", "n.age"]
      ordered: true
      rows:
        - [Gus, 25]
        - [Alix, 30]
